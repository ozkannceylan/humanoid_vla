<!--
  sim/g1_with_camera.xml
  Standalone scene for Unitree G1 with egocentric camera.

  Uses sim/models/g1_29dof.xml (local copy of upstream, camera added directly
  to torso_link body). Mesh path is patched in the local copy to point to repos/.

  Camera position tuning: run test_g1.py and adjust pos in
  sim/models/g1_29dof.xml until ego_camera view looks like a head-mounted
  forward-facing camera.
-->
<mujoco model="g1_with_camera">

  <include file="models/g1_29dof.xml"/>

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Fixed overhead camera for debugging / demo monitoring -->
    <camera name="scene_camera" pos="0.3 -0.8 1.6" xyaxes="1 0 0 0 0.5 1"/>

    <!-- Table for manipulation tasks — within right arm workspace.
         Table top at z=0.8 (half-height 0.4, pos 0 0 0.4). -->
    <body name="table" pos="0.3 -0.1 0">
      <geom type="box" size="0.2 0.2 0.4" pos="0 0 0.4" rgba="0.6 0.4 0.2 1"/>
      <!-- Phase C: place target — blue circle marker on table surface.
           World position: (0.3-0.1, -0.1+0.1, 0.802) = (0.2, 0.0, 0.802).
           contype/conaffinity=0 so it doesn't interfere with physics. -->
      <geom name="place_marker" type="cylinder" size="0.04 0.002" pos="-0.1 0.1 0.802"
            rgba="0.2 0.2 0.9 1" contype="0" conaffinity="0"/>
      <site name="place_site" pos="-0.1 0.1 0.825" size="0.005" rgba="0 0 0 0"/>
    </body>

    <!-- Red cube on table — Phase B manipulation target.
         Freejoint so it can be displaced by the robot hand.
         Table top is at z=0.8; cube half-size=0.025 → centre z=0.825
         Position chosen for comfortable right-arm reach (x=0.3, y=-0.1). -->
    <body name="red_cube" pos="0.3 -0.1 0.825">
      <freejoint name="cube_joint"/>
      <geom name="cube_geom" type="box" size="0.025 0.025 0.025" rgba="0.9 0.1 0.1 1"
            mass="0.05" solimp="0.99 0.99 0.001" solref="0.01 1"/>
      <site name="cube_site" pos="0 0 0" size="0.005" rgba="0 0 0 0"/>
    </body>

    <!-- Phase C2: Green box for bimanual manipulation.
         20×15×15cm (half-extents: 0.10×0.075×0.075). Mass 0.3kg.
         Centered at y=0 (robot midline) — symmetric for both arms.
         Table top at z=0.8 → box centre z = 0.8 + 0.075 = 0.875.
         condim=4 enables torsional friction for stable grasp.
         High friction (1.5) simulates rubber-on-cardboard contact. -->
    <body name="green_box" pos="0.3 0.0 0.875">
      <freejoint name="box_joint"/>
      <geom name="box_geom" type="box" size="0.10 0.075 0.075"
            rgba="0.2 0.7 0.2 1" mass="0.3"
            friction="1.5 0.005 0.0001" condim="4"
            solimp="0.95 0.95 0.001" solref="0.01 1"/>
      <site name="box_site" pos="0 0 0" size="0.005" rgba="0 0 0 0"/>
    </body>
  </worldbody>

  <!-- Grasp weld: attaches cube to right hand. Disabled by default;
       enabled at runtime by task_commander when hand is close enough. -->
  <equality>
    <weld name="grasp_weld" body1="right_wrist_yaw_link" body2="red_cube"
          relpose="0.1 0 0 1 0 0 0" active="false"/>
  </equality>

</mujoco>
